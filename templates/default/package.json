    "otok": "latest",
    "preact": "^10.28.2"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.21.0",
    "@otok/vite-plugin": "latest",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  }
