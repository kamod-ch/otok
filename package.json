{
  "name": "otok-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Klaus Zahiragic <watzak>",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter playground build",
    "check:scaffold": "node ./scripts/sync-scaffold.mjs --check",
    "dev": "pnpm --filter playground dev",
    "preview": "pnpm --filter playground preview",
    "sync:scaffold": "node ./scripts/sync-scaffold.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter playground test:e2e",
    "check": "pnpm check:scaffold && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.4"
}
