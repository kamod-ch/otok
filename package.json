{
  "name": "otok-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Klaus Zahiragic <watzak>",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter playground build && pnpm --filter docs build",
    "check:scaffold": "node ./scripts/sync-scaffold.mjs --check",
    "changeset": "pnpm dlx @changesets/cli",
    "dev": "pnpm --filter playground dev",
    "format:check": "node ./scripts/format-check.mjs",
    "format": "node ./scripts/format-check.mjs",
    "lint": "node ./scripts/lint.mjs",
    "metadata:check": "node ./scripts/verify-package-metadata.mjs",
    "pack:check": "pnpm metadata:check && pnpm -r --filter './packages/*' build && pnpm -r --filter './packages/*' exec npm pack --dry-run",
    "preview": "pnpm --filter playground preview",
    "release": "pnpm release:check && pnpm release:publish",
    "release:check": "pnpm check && pnpm test:e2e && pnpm pack:check",
    "release:publish": "pnpm dlx @changesets/cli publish",
    "smoke:node": "node ./scripts/production-smoke.mjs",
    "sync:scaffold": "node ./scripts/sync-scaffold.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter playground test:e2e",
    "version-packages": "pnpm dlx @changesets/cli version",
    "check": "pnpm check:scaffold && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.4"
}
