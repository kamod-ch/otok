{
  "name": "otok-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build --mode client",
    "build:server": "vite build",
    "preview": "vite preview",
    "start": "node dist/server/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "hono": "^4.12.25",
    "otok": "^0.3.0",
    "preact": "^10.28.2"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.21.0",
    "@otok/vite-plugin": "^0.3.0",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  }
}
