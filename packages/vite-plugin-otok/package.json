{
  "name": "@otok/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin for Otok file routes and Preact islands.",
  "type": "module",
  "files": ["dist", "client.d.ts"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "vite": ">=6"
  }
}
