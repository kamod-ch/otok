{
  "name": "@otok/vite-plugin",
  "version": "0.3.0",
  "description": "Vite plugin for Otok file routes and Preact islands.",
  "license": "MIT",
  "homepage": "https://github.com/kamod-ch/otok/tree/main/packages/vite-plugin-otok#readme",
  "bugs": {
    "url": "https://github.com/kamod-ch/otok/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamod-ch/otok.git",
    "directory": "packages/vite-plugin-otok"
  },
  "type": "module",
  "files": [
    "dist",
    "client.d.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm typecheck:typed-routes",
    "typecheck:typed-routes": "tsc -p fixtures/tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "vite": ">=6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
