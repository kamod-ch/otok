{
  "name": "@otok/test",
  "version": "0.2.0",
  "description": "Server-side testing utilities for Otok apps.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamod/otok",
    "directory": "packages/otok-test"
  },
  "type": "module",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "otok": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4",
    "preact": ">=10.26.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "hono": "^4.12.25",
    "preact": "^10.28.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  }
}
